doctype html
html(lang="es")
	head
		meta(charset="UTF-8")
		meta(name="viewport", content="width=device-width, initial-scale=1.0")
		title Nuevo Producto
		style.
			body {
				margin: 0;
				font-family: "Trebuchet MS", "Segoe UI", sans-serif;
				background: #f7f3ea;
				color: #231c15;
			}
			main {
				max-width: 700px;
				margin: 1.2rem auto;
				padding: 1rem;
			}
			.card {
				background: #fff;
				border: 1px solid #ddcfb7;
				border-radius: 12px;
				padding: 1rem;
			}
			form {
				display: grid;
				gap: .7rem;
			}
			input, textarea {
				padding: .65rem;
				border: 1px solid #cabba1;
				border-radius: 8px;
				width: 100%;
			}
			.row {
				display: grid;
				grid-template-columns: 1fr 1fr;
				gap: .7rem;
			}
			button, a {
				border: 0;
				border-radius: 8px;
				padding: .6rem .9rem;
				text-decoration: none;
				cursor: pointer;
				font-weight: 700;
			}
			button { background: #8d4f16; color: #fff; }
			a { background: #d9ad67; color: #3b2308; display: inline-block; }
			#msg { margin-top: .7rem; }
			@media (max-width: 640px) { .row { grid-template-columns: 1fr; } }
	body
		main
			.card
				h1 Alta de Producto
				p Crea un producto nuevo para el catalogo.
				form#formNuevoProducto
					input(type="text", name="nombre", placeholder="Nombre", required=true)
					textarea(name="descripcion", placeholder="Descripcion", rows="4")
					.row
						input(type="number", name="precio", placeholder="Precio", step="0.01", min="0.01", required=true)
						input(type="text", name="categoria", placeholder="Categoria", required=true)
					.row
						button(type="submit") Guardar producto
						a(href="/productos") Volver al listado
				p#msg

		script.
			const form = document.getElementById('formNuevoProducto');
			const msg = document.getElementById('msg');

			function setMsg(texto, ok) {
				msg.textContent = texto;
				msg.style.color = ok ? '#0f766e' : '#b91c1c';
			}

			form.addEventListener('submit', async (e) => {
				e.preventDefault();
				const fd = new FormData(form);
				const payload = {
					nombre: String(fd.get('nombre') || '').trim(),
					descripcion: String(fd.get('descripcion') || '').trim(),
					precio: Number(fd.get('precio')),
					categoria: String(fd.get('categoria') || '').trim()
				};
				try {
					const res = await fetch('/api/productos', {
						method: 'POST',
						headers: { 'Content-Type': 'application/json' },
						body: JSON.stringify(payload)
					});
					const data = await res.json();
					if (!res.ok) throw new Error(data.error || 'No se pudo crear');
					setMsg('Producto creado correctamente', true);
					form.reset();
				} catch (err) {
					setMsg(err.message, false);
				}
			});
