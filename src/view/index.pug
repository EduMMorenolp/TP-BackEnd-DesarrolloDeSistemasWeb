doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    title La Espiga de Oro - Panel
    style.
      :root {
        --bg: #f2efe8;
        --ink: #1f1a14;
        --soft: #fffdf7;
        --card: #ffffff;
        --line: #d8d0c2;
        --brand: #8d4f16;
        --brand-2: #e2b874;
      }

      * { box-sizing: border-box; }

      body {
        margin: 0;
        font-family: "Trebuchet MS", "Segoe UI", sans-serif;
        color: var(--ink);
        background:
          radial-gradient(circle at 20% 10%, #ffe8bd 0%, transparent 35%),
          radial-gradient(circle at 90% 90%, #f6d6a3 0%, transparent 35%),
          var(--bg);
        min-height: 100vh;
      }

      main {
        max-width: 1000px;
        margin: 0 auto;
        padding: 2rem 1rem 3rem;
      }

      .hero {
        background: linear-gradient(125deg, #fff8ec 0%, #ffe5b8 100%);
        border: 1px solid var(--line);
        border-radius: 18px;
        padding: 1.5rem;
      }

      h1 {
        margin: 0 0 .5rem;
        font-size: clamp(1.7rem, 5vw, 2.6rem);
      }

      p {
        margin: 0;
        line-height: 1.5;
      }

      .grid {
        margin-top: 1.2rem;
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: .9rem;
      }

      .card {
        background: var(--card);
        border: 1px solid var(--line);
        border-radius: 14px;
        padding: 1rem;
        box-shadow: 0 8px 18px rgba(73, 45, 10, .08);
      }

      .card h2 {
        margin-top: 0;
        margin-bottom: .5rem;
        font-size: 1.1rem;
      }

      .card p {
        margin-bottom: .8rem;
        font-size: .95rem;
      }

      .actions {
        display: flex;
        gap: .6rem;
        flex-wrap: wrap;
      }

      a.btn {
        text-decoration: none;
        border: 1px solid transparent;
        border-radius: 10px;
        padding: .6rem .8rem;
        background: var(--brand);
        color: #fff;
        font-weight: 700;
      }

      a.btn.secondary {
        background: var(--brand-2);
        color: #3d280d;
      }

      .foot {
        margin-top: 1rem;
        font-size: .9rem;
        opacity: .85;
      }
  body
    main
      section.hero
        h1 La Espiga de Oro
        p Sistema de gestion de pedidos para sucursales y franquicias.
      section.grid
        article.card
          h2 Modulo Sucursales
          p Alta, consulta, actualizacion y baja logica de sucursales y franquicias.
          .actions
            a.btn(href="/sucursales") Ir a Sucursales
        article.card
          h2 Modulo Productos
          p Catalogo de productos con validaciones de precio y disponibilidad.
          .actions
            a.btn(href="/productos") Ver Productos
        article.card
          h2 Modulo Pedidos
          p Creacion y seguimiento de pedidos con flujo de estados.
          .actions
            a.btn(href="/pedidos") Ver Pedidos
      p.foot Grupo Clouds